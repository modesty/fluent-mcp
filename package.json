{
  "name": "@modesty/fluent-mcp",
  "version": "0.4.1",
  "description": "MCP server for Fluent (ServiceNow SDK)",
  "keywords": [
    "Servicenow SDK",
    "Fluent",
    "mcp",
    "MCP Server",
    "sdk",
    "model-context-protocol",
    "DSL",
    "domain specific language MCP"
  ],
  "author": {
    "name": "Modesty Zhang",
    "email": "modestyz@hotmail.com",
    "url": "https://www.google.com/search?q=modesty+zhang+site%3Acodeproject.com"
  },
  "homepage": "https://github.com/modesty/fluent-mcp",
  "repository": {
    "type": "git",
    "url": "git://github.com/modesty/fluent-mcp.git"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "fluent-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "build:dev": "rollup -c rollup.config.mjs --environment NODE_ENV:development",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "eslint 'src/**/*.ts' --config eslint.config.js",
    "lint:fix": "eslint 'src/**/*.ts' --config eslint.config.js --fix",
    "test": "jest",
    "validate:snippets": "bash .mosey/scripts/validate-snippets.sh",
    "validate:specs": "node .mosey/scripts/validate-specs.mjs",
    "validate:instructs": "node .mosey/scripts/validate-instructs.mjs",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "inspect:dev": "npx @modelcontextprotocol/inspector ts-node src/index.ts",
    "inspect:published": "npx @modelcontextprotocol/inspector npx @modesty/fluent-mcp"
  },
  "type": "module",
  "engines": {
    "node": ">=20.18.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": ">=11.4.1"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@servicenow/sdk": "4.8.1",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "jest": "^30.4.2",
    "rollup": "^4.62.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "~6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "files": [
    "dist",
    "res"
  ]
}
